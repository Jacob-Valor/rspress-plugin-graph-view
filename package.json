{
  "name": "rspress-plugin-graph-view",
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive graph visualization for Rspress documentation sites — visualize your knowledge base connections like Obsidian",
  "files": [
    "src",
    "theme",
    "README.md"
  ],
  "keywords": [
    "rspress",
    "rspress-plugin",
    "graph-view",
    "knowledge-graph",
    "documentation",
    "visualization",
    "force-graph"
  ],
  "homepage": "https://github.com/Jacob-Valor/rspress-plugin-graph-view",
  "bugs": {
    "url": "https://github.com/Jacob-Valor/rspress-plugin-graph-view/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jacob-Valor/rspress-plugin-graph-view.git"
  },
  "packageManager": "bun@1.3.13",
  "license": "MIT",
  "author": "Jacob-Valor <jacob-programmer@tuta.io> (https://github.com/Jacob-Valor)",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./runtime/*": {
      "types": "./src/runtime/*",
      "import": "./src/runtime/*",
      "default": "./src/runtime/*"
    }
  },
  "scripts": {
    "bench:graph": "bun scripts/bench-graph-build.ts",
    "build": "tsc",
    "dev": "tsc -w",
    "docs:build": "rspress build",
    "docs:dev": "rspress dev",
    "test": "bun test",
    "prepublishOnly": "bun run build && bun run test"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "semantic-release": "25.0.3",
    "typescript": "6.0.3"
  },
  "publishConfig": {
    "provenance": true
  },
  "peerDependencies": {
    "@rspress/core": "2.0.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-force-graph-2d": "1.29.1",
    "typescript": ">=5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "mdast-util-from-markdown": "2.0.3",
    "unist-util-visit": "5.0.0"
  },
  "overrides": {
    "entities": "8.0.0"
  }
}
