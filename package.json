{
  "name": "rspress-plugin-graph-view",
  "version": "0.0.1",
  "description": "Interactive graph visualization for Rspress documentation sites — visualize your knowledge base connections like Obsidian",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rstackjs/rspress-plugin-graph-view"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./runtime/*": {
      "import": "./src/runtime/*",
      "default": "./src/runtime/*"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "theme"
  ],
  "scripts": {
    "bench:graph": "bun scripts/bench-graph-build.ts",
    "build": "tsc --declarationMap false",
    "dev": "tsc -w",
    "docs:build": "rspress build",
    "docs:dev": "rspress dev",
    "test": "bun test",
    "prepublishOnly": "bun run build && bun run test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "@rspress/core": "^2.0.7",
    "react": ">=18",
    "react-dom": ">=18",
    "react-force-graph-2d": "^1.29.1",
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
